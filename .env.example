# VARIABLES DE ENTORNO - PLANTILLA
# Copia este archivo a .env y reemplaza los valores
# ⚠️ NUNCA subas .env a GitHub

# =============================
# APLICACIÓN
# =============================
APP_PROFILE=dev
APP_NAME=demostracion
SERVER_PORT=8081

# =============================
# BASE DE DATOS MYSQL
# =============================
DB_URL=jdbc:mysql://localhost:3306/auto
DB_USERNAME=root
DB_PASSWORD=
DB_DRIVER=com.mysql.cj.jdbc.Driver

# =============================
# CORREO SMTP
# =============================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=autochecklistoficial@gmail.com
MAIL_PASSWORD=nmurogifknsmzlkf
MAIL_DEBUG=true

# =============================
# CORREO IMAP (RECIBIR)
# =============================
MAIL_INBOUND_PROTOCOL=imaps
MAIL_INBOUND_HOST=imap.gmail.com
MAIL_INBOUND_PORT=993
MAIL_INBOUND_USERNAME=autochecklistoficial@gmail.com
MAIL_INBOUND_PASSWORD=nmurogifknsmzlkf
MAIL_INBOUND_POLL_INTERVAL=60000

# =============================
# SEGURIDAD
# =============================
JWT_SECRET=tu-secreto-jwt-muy-largo-y-aleatorio-min-256-bits
BCrypt_STRENGTH=12

# =============================
# REDIS (Opcional)
# =============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================
# KEYSTORE PARA HTTPS (PRODUCCIÓN)
# =============================
# KEYSTORE_PATH=/path/to/keystore.p12
